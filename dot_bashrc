# If zsh is available, switch to it
if [ -x "$(command -v zsh)" ]; then
  exec zsh -l
fi

# Fallback bash config if zsh isn't installed yet
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

if [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
fi

if [ -f ~/.env ]; then
    export $(grep -v '^#' ~/.env | xargs)
fi

alias ff="fastfetch"
